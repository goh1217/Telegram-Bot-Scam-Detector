# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to git!

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your server domain (optional, for production webhook deployment)
TELEGRAM_WEBHOOK_URL=https://your-domain.com

# Get free from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL (optional)
DATABASE_URL=sqlite:///./scam_detector.db

# Webhook port (optional, defaults to 8000)
WEBHOOK_PORT=8000
